# Copy to .env.local and fill in to enable REAL Google sign-in.
# Leave unset to use the built-in mock login.
#
# Get a Client ID at https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID, type "Web application").
# Add your app's origin (e.g. http://localhost:5173) to "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=
